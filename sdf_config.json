{
  "description": "xSDF configuration file",

  "_comments": {
    "geometry_type": "Options: 'cube', 'cylinder', 'stl'",
    "backend_method": "Options: 'torch' (GPU), 'trimesh' (CPU)",
    "grid_stretch": "Set r_max=1.0 for uniform spacing, >1.0 for stretching",
    "grid_null_values": "null values in stretch_axes inherit from target_min_size and stretch_factor"
  },

  "output": {
    "save_name": "stretch_test_NEW2.h5",
    "visualize": true
  },

  "domain": {
    "bounds": {
      "x": [-5.0, 7.0],
      "y": [-3.0, 3.0],
      "z": [0.0, 6.0]
    }
  },

  "geometry": {
    "type": "stl",
    "path": "hydrofoil_original.ply",
    "transformations": {
      "scale": 0.05,
      "translate": [0.0, 0.0, -0.1],
      "rotate": [0.0, 0.0, 18.0]
    }
  },

  "grid": {
    "target_min_size": 0.05,
    "stretch_factor": 1.075,
    "stretch_axes": {
      "x": {
        "center": 0.0,
        "dx_min": null,
        "r_max": 1.025
      },
      "y": {
        "center": 0.0,
        "dx_min": null,
        "r_max": null
      },
      "z": {
        "center": 4.35,
        "dx_min": null,
        "r_max": null
      }
    },
    "preview_stretch": true
  },

  "backend": {
    "method": "torch",
    "memory_budget_gb": 8.0,
    "torch": {
      "device": "mps",
      "use_accel": true,
      "compile_kernels": false
    }
  }
}
